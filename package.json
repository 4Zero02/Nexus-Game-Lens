{
  "name": "ngl",
  "version": "1.0.1",
  "description": "Nexus Game Lens — HUD desktop app for esports observer events",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite build --config vite.panel.config.js --watch\" \"vite build --config vite.output.config.js --watch\" \"wait-on dist/panel/index.html dist/output/index.html && electron .\"",
    "build": "vite build --config vite.panel.config.js && vite build --config vite.output.config.js && electron-builder",
    "build:publish": "vite build --config vite.panel.config.js && vite build --config vite.output.config.js && electron-builder --publish always",
    "lint": "eslint .",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "Nexus Elite",
  "license": "ISC",
  "dependencies": {
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.27",
    "chokidar": "^3.5.3",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.56.0",
    "postcss": "^8.5.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "socket.io-client": "^4.7.2",
    "tailwindcss": "^3.4.19",
    "vite": "^5.0.11",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.nexuselite.ngl",
    "productName": "NGL - Nexus Game Lens",
    "executableName": "ngl",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "4Zero02",
        "repo": "Nexus-Game-Lens"
      }
    ],
    "files": [
      "electron/**/*",
      "server/**/*",
      "dist/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/favicon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    }
  }
}